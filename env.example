# Copy to .env and set values as needed.
# See README for details.

# Contact form for server deployments (Vercel/Node).
# Payload: { name, email, subject, message }. If unset, the Next API route returns 503.
# CONTACT_API_URL=https://api.example.com/contact

# Contact form for static shared-hosting exports.
# When set, the contact page posts directly to this backend endpoint instead of /api/contact.
# NEXT_PUBLIC_CONTACT_API_URL=https://api.example.com/contact
